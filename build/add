<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="main-content">
    <div class="container mt-4 mb-5">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">
                <h2 class="mb-0" style="color: white;">Add New Location</h2>
            </div>
            <div class="card-body">

                <form id="addLocationForm" method="POST" action="/create" enctype="multipart/form-data">

                    <fieldset class="mb-4">
                        <legend class="h5 mb-3 text-secondary">Location Details</legend>
                        <div class="mb-3">
                            <label for="location_name" class="form-label font-weight-bold">Location Name:</label>
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <input type="text" class="form-control" id="location_name" name="location_name" required style="flex-grow: 1;">
                                <button type="button" id="geocode_button" class="btn btn-secondary d-flex align-items-center gap-2" title="Find coordinates by name">
                                    <span id="geocode-spinner" class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="display: none;"></span>
                                    <span id="geocode-text">Find Coords</span>
                                </button>
                            </div>
                        </div>

                        <div class="mb-3"> 
                            <label for="country" class="form-label font-weight-bold">Country:</label>
                            <input type="text" class="form-control" id="country" name="country" value="">
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="latitude" class="form-label font-weight-bold">Latitude:</label>
                                <input type="number" step="any" class="form-control" id="latitude" name="latitude" required placeholder="e.g., 54.6709">
                            </div>
                            <div class="col-md-6">
                                <label for="longitude" class="form-label font-weight-bold">Longitude:</label>
                                <input type="number" step="any" class="form-control" id="longitude" name="longitude" required placeholder="e.g., 25.2818">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label font-weight-bold">Select Location on Map:</label>
                            <div id="mini-map" style="height: 220px; border-radius: 8px; border: 1px solid #ced4da; z-index: 1;"></div>
                            <div class="form-text text-muted">Click anywhere on the map to place a pin, or drag it to refine coordinates.</div>
                        </div>
                    </fieldset>

                    <fieldset class="mb-4">
                        <legend class="h5 mb-3 text-secondary">Images</legend>
                        <div class="mb-3">
                            <label for="photos" class="form-label font-weight-bold">Upload Photo(s) (Optional):</label>
                            <!-- File input -->
                            <input type="file" class="form-control" id="photos" name="photos" accept="image/*" multiple>
                            <div class="form-text text-muted">Select one or more image files. You can **drag** to reorder them and click the **&times;** button to remove them.</div>
                            
                            <!-- Preview Grid container -->
                            <div id="image-preview" class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3 mt-3 sortable-container"></div>
                        </div>

                        <div class="mb-3">
                             <label for="img_orient" class="form-label font-weight-bold">Image Orientation (for popup display):</label>
                             <select class="form-select" id="img_orient" name="img_orient">
                                 <option value="1" selected>Vertical / Default (Tall Popup)</option>
                                 <option value="2">Horizontal (Shorter Popup for single image)</option>
                             </select>
                        </div>
                    </fieldset>

                    <div class="d-flex justify-content-end">
                        <a href="/" class="btn btn-secondary me-2">Cancel</a>
                        <button type="submit" class="btn btn-success">Add Location</button>
                    </div>

                </form>
            </div> <!-- card-body -->
