<!-- Load Bootstrap JS & SortableJS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>

<script>
    // Global array to manage uploaded files
    let uploadedFiles = [];

    document.addEventListener('DOMContentLoaded', function() {
        const nameInput = document.getElementById('location_name');
        const latInput = document.getElementById('latitude');
        const lonInput = document.getElementById('longitude');
        const countryInput = document.getElementById('country');
        const geocodeButton = document.getElementById('geocode_button');
        const fileInput = document.getElementById('photos');
        const form = document.getElementById('addLocationForm');
        const previewContainer = document.getElementById('image-preview');

        // --- Leaflet Mini Map Initialization ---
        const miniMap = L.map('mini-map').setView([20, 0], 2);
        L.tileLayer('https://tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 19,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(miniMap);

        let miniMapMarker = null;

        function updateMiniMapMarker(lat, lon, animate = true) {
            if (miniMapMarker) {
                miniMapMarker.setLatLng([lat, lon]);
            } else {
                miniMapMarker = L.marker([lat, lon], { draggable: true }).addTo(miniMap);
                miniMapMarker.on('dragend', function() {
                    const position = miniMapMarker.getLatLng();
                    latInput.value = position.lat.toFixed(6);
                    lonInput.value = position.lng.toFixed(6);
                });
            }
            if (animate) {
                miniMap.setView([lat, lon], 12);
            } else {
                miniMap.panTo([lat, lon]);
            }
        }

        // Map click places pin
        miniMap.on('click', function(event) {
            const lat = event.latlng.lat;
            const lon = event.latlng.lng;
            latInput.value = lat.toFixed(6);
            lonInput.value = lon.toFixed(6);
            updateMiniMapMarker(lat, lon, false);
        });

        // Form changes update map marker
        function handleManualCoordsChange() {
            const lat = parseFloat(latInput.value);
            const lon = parseFloat(lonInput.value);
            if (!isNaN(lat) && !isNaN(lon)) {
                updateMiniMapMarker(lat, lon, false);
            }
        }
        latInput.addEventListener('input', handleManualCoordsChange);
        lonInput.addEventListener('input', handleManualCoordsChange);

        // --- SortableJS PREVIEW ---
        const sortable = Sortable.create(previewContainer, {
            animation: 150,
            ghostClass: 'sortable-ghost',
            chosenClass: 'sortable-chosen',
            filter: '.remove-btn',
            preventOnFilter: false,
            onEnd: function() {
                reorderFilesArray();
            }
        });

        // Handle File Selection
        fileInput.addEventListener('change', function(event) {
            const files = event.target.files;
            if (files) {
                Array.from(files).forEach(file => {
                    if (file.type.startsWith('image/')) {
                        const fileId = 'file_' + Math.random().toString(36).substr(2, 9);
                        const objectUrl = URL.createObjectURL(file);
                        uploadedFiles.push({
                            id: fileId,
                            file: file,
                            url: objectUrl
                        });
                    }
                });
                renderPreviews();
            }
            fileInput.value = '';
        });

        // Render Preview Thumbnails
        function renderPreviews() {
            previewContainer.innerHTML = '';
            if (uploadedFiles.length === 0) return;

            uploadedFiles.forEach((fileObj) => {
                const col = document.createElement('div');
                col.className = 'col sortable-item';
                col.setAttribute('data-id', fileObj.id);
                
                col.innerHTML = `
                    <div class="card preview-image-card text-center p-2 border rounded bg-light position-relative" style="cursor: grab;">
                        <img src="${fileObj.url}" alt="${fileObj.file.name}" class="img-thumbnail mb-2" style="max-height: 80px; width: auto; display: block; margin: 0 auto;">
                        <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0 m-1 remove-btn" data-id="${fileObj.id}" style="line-height: 1; padding: 2px 6px;">&times;</button>
                        <div class="small text-truncate text-muted px-1" style="font-size: 11px;">${fileObj.file.name}</div>
                    </div>
                `;
                col.querySelector('.remove-btn').addEventListener('click', function() {
                    removeFile(fileObj.id);
                });
                previewContainer.appendChild(col);
            });
        }

        window.removeFile = function(id) {
            const index = uploadedFiles.findIndex(item => item.id === id);
            if (index > -1) {
                URL.revokeObjectURL(uploadedFiles[index].url);
                uploadedFiles.splice(index, 1);
                renderPreviews();
            }
        };

        function reorderFilesArray() {
            const sortedIds = Array.from(previewContainer.querySelectorAll('.sortable-item')).map(item => item.getAttribute('data-id'));
            const reordered = [];
            sortedIds.forEach(id => {
                const fileObj = uploadedFiles.find(item => item.id === id);
                if (fileObj) {
                    reordered.push(fileObj);
                }
            });
            uploadedFiles = reordered;
        }

        // Geocoding with Loading feedback
        async function fetchCoordinates() {
            const locationName = nameInput.value.trim();
            if (!locationName) {
                alert('Please enter a location name first.');
                return;
            }

            const spinner = document.getElementById('geocode-spinner');
            const btnText = document.getElementById('geocode-text');

            spinner.style.display = 'inline-block';
            btnText.textContent = 'Searching...';
            geocodeButton.disabled = true;
            nameInput.disabled = true;

            try {
                const response = await fetch(`/geocode?location_name=${encodeURIComponent(locationName)}`);
                if (response.ok) {
                    const data = await response.json();
                    if (data.latitude && data.longitude) {
                        latInput.value = data.latitude.toFixed(6);
                        lonInput.value = data.longitude.toFixed(6);
                        if (data.country) {
                            countryInput.value = data.country;
                        }
                        updateMiniMapMarker(data.latitude, data.longitude, true);
                    } else {
                        alert('Could not find coordinates for this location. Please enter them manually.');
                    }
                } else {
                    const errorData = await response.json();
                    alert(`Geocoding failed: ${errorData.error || response.statusText}`);
                }
            } catch (error) {
                alert('An error occurred while trying to find coordinates.');
                console.error(error);
            } finally {
                spinner.style.display = 'none';
                btnText.textContent = 'Find Coords';
                geocodeButton.disabled = false;
                nameInput.disabled = false;
            }
        }

        geocodeButton.addEventListener('click', fetchCoordinates);

        // Helper: File to compressed Base64 using HTML5 Canvas
        function fileToBase64(fileObj) {
            return new Promise((resolve, reject) => {
                const img = new Image();
                img.src = fileObj.url;
                img.onload = function() {
                    const canvas = document.createElement('canvas');
                    const ctx = canvas.getContext('2d');
                    
                    const MAX_WIDTH = 400;
                    const MAX_HEIGHT = 400;
                    let width = img.width;
                    let height = img.height;
                    
                    if (width > height) {
                        if (width > MAX_WIDTH) {
                            height *= MAX_WIDTH / width;
                            width = MAX_WIDTH;
                        }
                    } else {
                        if (height > MAX_HEIGHT) {
                            width *= MAX_HEIGHT / height;
                            height = MAX_HEIGHT;
                        }
                    }
                    
                    canvas.width = width;
                    canvas.height = height;
                    ctx.drawImage(img, 0, 0, width, height);
                    
                    const dataUrl = canvas.toDataURL('image/jpeg', 0.7);
                    resolve(dataUrl);
                };
                img.onerror = function() {
                    reject(new Error('Failed to load image'));
                };
            });
        }

        // Submit listener displaying the demo modal and saving to localStorage
        form.addEventListener('submit', function(event) {
            event.preventDefault();
            
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            const subBtn = form.querySelector('button[type="submit"]');
            const origSubText = subBtn.innerHTML;
            subBtn.disabled = true;
            subBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>Saving...';

            // Convert images to Base64 and save to localStorage
            const imagePromises = uploadedFiles.map(fileObj => fileToBase64(fileObj));
            
            Promise.all(imagePromises).then(base64Images => {
                const newLocation = {
                    name: nameInput.value.trim(),
                    latitude: parseFloat(latInput.value),
                    longitude: parseFloat(lonInput.value),
                    country: countryInput.value.trim(),
                    images: base64Images,
                    img_orient: document.getElementById('img_orient').value
                };

                const localLocations = JSON.parse(localStorage.getItem('local_places_visited') || '[]');
                localLocations.push(newLocation);
                localStorage.setItem('local_places_visited', JSON.stringify(localLocations));

                // Populate images into modal to show order
                const modalImagesPreview = document.getElementById('modalImagesPreview');
                const modalImagesSection = document.getElementById('modalImagesSection');
                modalImagesPreview.innerHTML = '';

                document.getElementById('modalLocationName').textContent = newLocation.name;

                if (newLocation.images.length > 0) {
                    modalImagesSection.style.display = 'block';
                    newLocation.images.forEach((base64Src, index) => {
                        const imgContainer = document.createElement('div');
                        imgContainer.className = 'text-center border rounded p-1 bg-light';
                        imgContainer.style.width = '80px';
                        imgContainer.innerHTML = `
                            <img src="${base64Src}" class="img-thumbnail" style="height: 50px; width: auto; object-fit: cover; display: block; margin: 0 auto 3px auto;">
                            <div class="text-truncate text-muted" style="font-size: 9px; max-width: 70px;">Image ${index + 1}</div>
                        `;
                        modalImagesPreview.appendChild(imgContainer);
                    });
                } else {
                    modalImagesSection.style.display = 'none';
                }

                subBtn.disabled = false;
                subBtn.innerHTML = origSubText;

                const demoModal = new bootstrap.Modal(document.getElementById('demoModal'));
                demoModal.show();

                // Redirect to homepage on modal close
                document.getElementById('demoModal').addEventListener('hidden.bs.modal', function () {
                    window.location.href = '/';
                });
            }).catch(err => {
                console.error(err);
                alert('Error processing images. Saving metadata only.');
                
                // Fallback: save without images
                const newLocation = {
                    name: nameInput.value.trim(),
                    latitude: parseFloat(latInput.value),
                    longitude: parseFloat(lonInput.value),
                    country: countryInput.value.trim(),
                    images: [],
                    img_orient: document.getElementById('img_orient').value
                };

                const localLocations = JSON.parse(localStorage.getItem('local_places_visited') || '[]');
                localLocations.push(newLocation);
                localStorage.setItem('local_places_visited', JSON.stringify(localLocations));

                document.getElementById('modalLocationName').textContent = newLocation.name;
                modalImagesSection.style.display = 'none';

                subBtn.disabled = false;
                subBtn.innerHTML = origSubText;

                const demoModal = new bootstrap.Modal(document.getElementById('demoModal'));
                demoModal.show();

                document.getElementById('demoModal').addEventListener('hidden.bs.modal', function () {
                    window.location.href = '/';
                });
            });
        });
    });
</script>

