    /* Стили контейнера книги */
    .book-container {
      all: unset;
      flex: initial;
      display: initial;
    }
    /* Basic styling for the timeline */
    .timeline {
      display: flex;
      flex-direction: column;
      width: 100%; /* Заголовок на всю ширину */
    }
    .year {
      margin-bottom: 20px;
      position: relative;
    }
    .year-title {
      background-color: #4CAF50;
      color: white;
      padding: 10px;
      margin: 0;
      cursor: pointer;
      width: 100%; /* Заголовок на всю ширину */
      box-sizing: border-box; /* Включаем padding в ширину */
    }
    .place {
      margin-bottom: 10px;
    }
    .place-title {
      font-weight: bold;
      margin-left: 2em;
      background-color: #f39c12;
      color: white;
      padding: 10px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      cursor: pointer;
      width: calc(100% - 2em); /* Заголовок на всю ширину, с учетом отступа слева */
      box-sizing: border-box; /* Включаем padding в ширину */
    }
    .place-title a {
      text-decoration: none;
      color: white;
    }
    .place-title a:hover {
      text-decoration: underline;
    }
    .entry {
      margin-bottom: 5px;
    }
    .images {
      display: flex;
      flex-wrap: wrap;
      gap: 5px;
      margin-left: 2em;
      margin-top: 1em;
    }
    .images img {
      height: 350px;
      display: block;
      width: auto;
      border: 2px solid #ccc;
    }
    /* Секции с фотографиями изначально показываются */
    .photos-container {
      /* display: none; */ /* Removed this line */
    }
    /* Стили для кнопок переключения внутри места */
    .toggle-button {
      cursor: pointer;
      margin-left: 10px;
      font-size: 16px;
      user-select: none;
    }
    /* Кнопка "Открыть все/Закрыть все" */
