      margin-bottom: 20px;
      padding: 10px 15px;
      background-color: #f39c12;
      color: white;
      border: none;
      cursor: pointer;
      font-size: 16px;
    }
    /* Прочие стили */
    .country-links {
      margin-bottom: 20px;
      width: 100%; /* Заголовок на всю ширину */
    }
    .country-links a {
      margin-right: 15px;
      text-decoration: none;
      color: #3498db;
    }
    .country-links a:hover {
      text-decoration: underline;
    }
    /*
    * Styles for the country blocks
    */
    .country {
        margin-left: 1em;
        margin-bottom: 1em;
    }
    .country-name {
        background-color: #3498db;  /* Цвет фона */
        color: white;               /* Цвет текста */
        padding: 10px;              /* Отступы внутри элемента */
        margin: 2;                  /* Убираем внешние отступы, если не нужно */
        width: calc(100% - 1em); /* Заголовок на всю ширину, с учетом отступа слева */
        box-sizing: border-box; /* Включаем padding в ширину */
    }
    .close-button {
      position: absolute;
      top: 20px;
      right: 20px;
      background-color: transparent;
      border: none;
      color: black;
      font-size: 24px;
      cursor: pointer;
    }
