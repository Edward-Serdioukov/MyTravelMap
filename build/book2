    <script>
        // Toggle single place collapsibility
        function togglePhotos(titleElement) {
            const placeDiv = titleElement.closest('.place');
            placeDiv.classList.toggle('collapsed');
        }

        // Toggle all sections visibility
        function toggleAllPhotos() {
            const btn = document.getElementById('toggle-all');
            const places = document.querySelectorAll('.place');
            const icon = btn.querySelector('i');
            const text = btn.querySelector('span');

            const isHiding = text.textContent.trim() === "Hide all photos";

            if (isHiding) {
                places.forEach(p => p.classList.add('collapsed'));
                icon.className = "fa fa-eye";
                text.textContent = "Show all photos";
            } else {
                places.forEach(p => p.classList.remove('collapsed'));
                icon.className = "fa fa-eye-slash";
                text.textContent = "Hide all photos";
            }
        }
    </script>
